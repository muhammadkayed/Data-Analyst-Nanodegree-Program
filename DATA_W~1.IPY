       "\n",
       "    function displayChart(vegaEmbed) {\n",
       "      vegaEmbed(outputDiv, spec, embedOpt)\n",
       "        .catch(err => showError(`Javascript Error: ${err.message}<br>This usually means there's a typo in your chart specification. See the javascript console for the full traceback.`));\n",
       "    }\n",
       "\n",
       "    if(typeof define === \"function\" && define.amd) {\n",
       "      requirejs.config({paths});\n",
       "      let deps = [\"vega-embed\"];\n",
       "      require(deps, displayChart, err => showError(`Error loading script: ${err.message}`));\n",
       "    } else {\n",
       "      maybeLoadScript(\"vega\", \"5\")\n",
       "        .then(() => maybeLoadScript(\"vega-lite\", \"5.20.1\"))\n",
       "        .then(() => maybeLoadScript(\"vega-embed\", \"6\"))\n",
       "        .catch(showError)\n",
       "        .then(() => displayChart(vegaEmbed));\n",
       "    }\n",
       "  })({\"config\": {\"view\": {\"continuousWidth\": 300, \"continuousHeight\": 300}}, \"layer\": [{\"mark\": {\"type\": \"bar\"}, \"encoding\": {\"color\": {\"field\": \"Country Name_x\", \"title\": \"Country\", \"type\": \"nominal\"}, \"tooltip\": [{\"field\": \"Country Name_x\", \"title\": \"Country\", \"type\": \"nominal\"}, {\"field\": \"Economic Year\", \"title\": \"Latest Year\", \"type\": \"quantitative\"}, {\"field\": \"Economic Value\", \"format\": \"$,.0f\", \"title\": \"Real GDP per Capita (Constant 2015 US$)\", \"type\": \"quantitative\"}], \"x\": {\"field\": \"Country Name_x\", \"sort\": \"-y\", \"title\": \"Country\", \"type\": \"nominal\"}, \"y\": {\"field\": \"Economic Value\", \"title\": \"Real GDP per Capita (Constant 2015 US$)\", \"type\": \"quantitative\"}}, \"name\": \"view_1\"}, {\"mark\": {\"type\": \"text\", \"align\": \"center\", \"baseline\": \"bottom\", \"dy\": -5}, \"encoding\": {\"color\": {\"value\": \"black\"}, \"text\": {\"field\": \"Economic Value\", \"format\": \"$,.0f\", \"type\": \"quantitative\"}, \"tooltip\": [{\"field\": \"Country Name_x\", \"title\": \"Country\", \"type\": \"nominal\"}, {\"field\": \"Economic Year\", \"title\": \"Latest Year\", \"type\": \"quantitative\"}, {\"field\": \"Economic Value\", \"format\": \"$,.0f\", \"title\": \"Real GDP per Capita (Constant 2015 US$)\", \"type\": \"quantitative\"}], \"x\": {\"field\": \"Country Name_x\", \"sort\": \"-y\", \"title\": \"Country\", \"type\": \"nominal\"}, \"y\": {\"field\": \"Economic Value\", \"title\": \"Real GDP per Capita (Constant 2015 US$)\", \"type\": \"quantitative\"}}}], \"data\": {\"name\": \"data-0445687426588c6051ecdbbdd62c27a5\"}, \"height\": 400, \"params\": [{\"name\": \"param_1\", \"select\": {\"type\": \"interval\", \"encodings\": [\"x\", \"y\"]}, \"bind\": \"scales\", \"views\": [\"view_1\"]}], \"title\": \"Real GDP per Capita (Constant 2015 US$) in the Latest Available Year (2020) for Top 5 Countries\", \"width\": 600, \"$schema\": \"https://vega.github.io/schema/vega-lite/v5.20.1.json\", \"datasets\": {\"data-0445687426588c6051ecdbbdd62c27a5\": [{\"Country Code\": \"CHN\", \"Country Name_x\": \"China\", \"Country Name_y\": \"China\", \"Series Name\": \"China\", \"Series Code\": \"NY.GDP.PCAP.KD\", \"Economic Year\": 2020, \"Economic Value\": 10370.359293128235}, {\"Country Code\": \"RUS\", \"Country Name_x\": \"Russian Federation\", \"Country Name_y\": \"Russian Federation\", \"Series Name\": \"Russian Federation\", \"Series Code\": \"NY.GDP.PCAP.KD\", \"Economic Year\": 2020, \"Economic Value\": 9666.81466421065}, {\"Country Code\": \"BRA\", \"Country Name_x\": \"Brazil\", \"Country Name_y\": \"Brazil\", \"Series Name\": \"Brazil\", \"Series Code\": \"NY.GDP.PCAP.KD\", \"Economic Year\": 2020, \"Economic Value\": 8228.780510420718}, {\"Country Code\": \"ZAF\", \"Country Name_x\": \"South Africa\", \"Country Name_y\": \"South Africa\", \"Series Name\": \"South Africa\", \"Series Code\": \"NY.GDP.PCAP.KD\", \"Economic Year\": 2020, \"Economic Value\": 5659.206948865713}, {\"Country Code\": \"IND\", \"Country Name_x\": \"India\", \"Country Name_y\": \"India\", \"Series Name\": \"India\", \"Series Code\": \"NY.GDP.PCAP.KD\", \"Economic Year\": 2020, \"Economic Value\": 1811.684237693253}]}}, {\"mode\": \"vega-lite\"});\n",
       "</script>"
      ],
      "text/plain": [
       "alt.LayerChart(...)"
      ]
     },
