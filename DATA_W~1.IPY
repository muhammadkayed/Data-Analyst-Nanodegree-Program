   "source": [
    "#Remove any footnotes or special characters from the 'Education and Environment Year' column e.g: remove  [YR1970] from 1970 [YR1970]\n",
    "edu_env_melted_df['Education and Environment Year'] = edu_env_melted_df['Education and Environment Year'].str.replace(r'\\s*\\[.*?\\]', '', regex=True)"
   ]
